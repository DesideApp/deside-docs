# MCP endpoint that this example client connects to.
MCP_BASE_URL=http://localhost:3100
MCP_PATH=/mcp

# Optional: if empty, script generates an ephemeral wallet each run.
# AGENT_SECRET_KEY_B58=

# Optional test target for send_dm.
# TO_WALLET=
TEXT=hello from deside mini-agent

LIST_LIMIT=20
READ_LIMIT=20

# 1 to wait for notifications/dm_received
WATCH_PUSH=0
PUSH_TIMEOUT_MS=15000

# Add llm:invoke when MINI_AGENT_LLM_FREE=1.
OAUTH_SCOPE=dm:read dm:write
OAUTH_CLIENT_NAME=deside-mini-agent
# Optional: defaults to {MCP_BASE_URL}/mini-agent/callback
# OAUTH_REDIRECT_URI=

# 1 to run read_dms -> llm_complete(free) -> send_dm when TO_WALLET is set.
# Requires OAUTH_SCOPE=dm:read dm:write llm:invoke.
MINI_AGENT_LLM_FREE=0
